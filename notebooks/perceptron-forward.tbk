] }
```

```scene step=3 narration="Hidden neuron 1: z = 0.8·0.8 + 0.6·(-0.4) + (-0.2) = 0.20. a = tanh(0.20) = 0.20. Light blue." code_lines=6-7
{ "primitives": [
  {"type":"nn","x":100,"y":90,"width":600,"height":320,
   "layers":[
     {"size":2,"label":"input","activations":[0.8,-0.4]},
     {"size":3,"label":"hidden","activations":[0.80,0.20,0]},
     {"size":1,"label":"output"}
   ],
   "weights":[[[1.0,-0.5],[0.8,0.6],[-0.4,0.9]],[[0.7,-0.3,0.5]]],
