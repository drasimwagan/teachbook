] }
```

```scene step=3 narration="t ≈ 1.02 s: peak. Vertical velocity = 0, horizontal velocity unchanged." code_lines=9
{ "primitives": [
  {"type":"axes","xMin":0,"xMax":40,"yMin":0,"yMax":8},
